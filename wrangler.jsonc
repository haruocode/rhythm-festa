{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rhythm-festa",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-31",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "RHYTHM_FESTA_BUCKET",
      "bucket_name": "rhythm-festa-assets"
    }
  ]
}
